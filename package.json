{
  "name": "trading-scraper",
  "version": "1.0.0",
  "description": "交易数据抓取工具",
  "main": "main.js",
  "scripts": {
    "start": "node proxy-server.js"
  },
  "dependencies": {},
  "build": {
    "appId": "com.trading.scraper",
    "productName": "交易数据抓取工具",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md,changelog.md,LICENSE,license,LICENSE.md}",
      "!node_modules/.cache/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Bluemelancholy1",
      "repo": "trading-scraper"
    }
  }
}
