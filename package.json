{
  "name": "trading-scraper",
  "version": "1.0.6",
  "description": "交易数据抓取工具",
  "author": "陈少",
  "main": "main.js",
  "scripts": {
    "start": "node proxy-server.js",
    "build": "electron-builder --win",
    "publish": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "41.2.1"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.trading.scraper",
    "productName": "交易数据抓取工具",
    "directories": {
      "output": "dist4"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "proxy-server.js",
      "package.json",
      "node_modules/electron-log/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/electron-log/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Bluemelancholy1",
      "repo": "trading-scraper",
      "releaseType": "release"
    }
  }
}
